{
    "name": "cfmlfiddle-lucee7",
    "app": {
        "cfengine": "lucee@7",
        "libDirs": "C:\\cfmlfiddle\\JavaLibs"
    },
    "dockEnable": true,
    "trayEnable": true,
    "json": {
        "ansiColors": {
            "constant": "48B9FF"
        }
    },
    "customTagPaths": [
        {
            "physical": "C:\\cfmlfiddle\\CustomTags",
            "primary": "physical"
        }
    ],
    "luceeConfig": {
        "customTagMappings": {
            "mapping": [
                {
                    "physical": "C:\\cfmlfiddle\\CustomTags",
                    "primary": "physical",
                    "virtual": "/customtags",
                    "readonly": false
                }
            ]
        }
    },
    "jvm": {
        "javaHome": "C:\\Program Files\\Java\\jre21",
        "args": [
            "-D:javax.xml.accessExternalDTD=''",
            "-D:javax.xml.accessExternalSchema=''",
            "-D:javax.xml.accessExternalStylesheet=''"
        ]
    },
    "web": {
        "host": "127.0.0.1",
        "hostAlias": "localhost",
        "webroot": "../www",
        "directoryBrowsing": true,
        "accessLogEnable": true,
        "blockCFAdmin": false,
        "blockSensitivePaths": true,
        "welcomeFiles": "index.cfm,index.html,index.htm",
        "gzipEnable": true,
        "blockFlashRemoting": true,
        "rewrites": {
            "enable": true
        },
        "HTTP": {
            "enable": true,
            "port": 13007
        },
        "mimeTypes": {
            "heic": "image/heic",
            "webmanifest": "application/manifest+json",
            "avif": "image/avif",
            "webp": "image/webp",
            "woff2": "font/woff2",
            "woff": "font/woff",
            "mjs": "text/javascript",
            "map": "application/json"
        },
        "allowedExt": "webmanifest,avif,webp,woff2,woff,mjs,map"
    },
    "debug": true,
    "trace": false,
    "console": false,
    "profile": "development",
    "openBrowser": false,
    "openBrowserURL": "http://localhost:13007/"
}
